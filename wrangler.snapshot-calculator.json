{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aftertaxus-snapshot-calculator",
  "main": "snapshot-calculator/worker.ts",
  "compatibility_date": "2026-06-28",
  "assets": {
    "binding": "ASSETS",
    "directory": "./snapshot-calculator/dist",
    "run_worker_first": true,
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "calculator.aftertaxus.com",
      "custom_domain": true
    }
  ]
}
